# =========================
# 1. LightRAG 知识库 API
# =========================
# 作用：访问你的 LightRAG Server，用于查文档、查状态、向知识库提问。
# 你给的 Web UI 地址可以先填这里，代码会自动去掉 /webui/#/，转成 API root。
LIGHTRAG_BASE_URL=http://192.168.130.130:9621/webui/#/

# 作用：LightRAG Server 自己的访问鉴权 key。
# 注意：这不是 OpenAI/DeepSeek/通义的 LLM key。
# 如果你的 LightRAG Server 没有开 API 鉴权，留空。
LIGHTRAG_API_KEY=

# 作用：LightRAG 查询模式。你的 OpenAPI 显示可选值：
# local/global/hybrid/naive/mix/bypass，默认是 mix。
# 具体可用值以你的 LightRAG Swagger/OpenAPI 文档为准。
LIGHTRAG_QUERY_MODE=mix

# 作用：控制知识库检索返回多少片段。如果 Swagger 支持 top_k，可以填整数。
# 不确定就先留空。
LIGHTRAG_TOP_K=

# 作用：让 /query 的 references 尽量带上原始 chunk 内容，便于专利写作引用素材。
LIGHTRAG_INCLUDE_CHUNK_CONTENT=true


# =========================
# 2. LLM 写作模型 API
# =========================
# 作用：后续用于把知识库素材和搜索结果改写成更像正式专利文档的成稿。
# 当前代码还没有真正调用 LLM；先把配置位留好。
#
# 可填示例：
#   ollama
#   openai
#   deepseek
#   qwen
#   azure_openai
#   custom_openai_compatible
#   none
LLM_PROVIDER=ollama

# 作用：LLM 服务商的 API key。
# OpenAI 填 OPENAI API key；DeepSeek 填 DeepSeek API key；
# 通义千问填 DashScope/阿里云百炼 key；公司内网模型填对应平台 key。
# Ollama 原生接口一般不需要 key，留空。
LLM_API_KEY=

# 作用：LLM 的 API base URL。
# OpenAI 官方可填：https://api.openai.com/v1
# DeepSeek 可填：https://api.deepseek.com
# OpenAI-compatible 私有服务填你们自己的 /v1 地址。
# Ollama 原生接口填服务根地址，不要加 /api/generate。
LLM_BASE_URL=http://192.168.130.130:9621

# 作用：具体调用的模型名。
# 示例：gpt-4.1、gpt-4.1-mini、deepseek-chat、qwen-plus 等。
# 你这个 LightRAG Server 的 /api/tags 当前返回 lightrag:latest。
LLM_MODEL=lightrag:latest


# =========================
# 3. 外部搜索 API
# =========================
# 作用：知识库访问失败或 no-context 时，搜索外部资料作为 fallback。
# 当前默认 duckduckgo 不需要 key，但稳定性一般。
# 后续如果接 Tavily/SerpAPI/Bing，可以在这里填 key。
#
# 可填示例：
#   duckduckgo
#   tavily
#   serpapi
#   bing
#   none
SEARCH_PROVIDER=duckduckgo

# 作用：外部搜索服务 API key。
# DuckDuckGo 留空；Tavily/SerpAPI/Bing 才需要填。
SEARCH_API_KEY=
