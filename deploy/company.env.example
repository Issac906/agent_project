# Web 服务
WEB_HOST=0.0.0.0
WEB_PORT=5000

# LightRAG 知识库 API
# 注意：容器里访问的是公司网络里的服务器地址，不要填 localhost，除非 LightRAG 也在同一个容器内。
LIGHTRAG_BASE_URL=http://192.168.130.130:9621/webui/#/
LIGHTRAG_API_KEY=
LIGHTRAG_QUERY_MODE=mix
LIGHTRAG_TOP_K=
LIGHTRAG_INCLUDE_CHUNK_CONTENT=true

# Agent 核：镜像内会安装 pi coding agent
AGENT_CORE=pi_coding_agent
PI_CODING_COMMAND=pi
PI_CODING_PROVIDER=deepseek
PI_CODING_MODEL=deepseek-chat
PI_CODING_TIMEOUT=600

# DeepSeek 凭据
# 如果公司服务器没有提前登录/配置 pi，就在这里填 DeepSeek API key。
# pi 官方参数说明里写着 --api-key 默认会读取环境变量。
DEEPSEEK_API_KEY=

# 外部搜索
SEARCH_PROVIDER=anysearch
ANYSEARCH_BASE_URL=
ANYSEARCH_TIMEOUT=10
SEARCH_API_KEY=
