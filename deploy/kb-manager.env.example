# Generate a long random value, for example: openssl rand -hex 32
KB_MANAGER_API_KEY=replace-with-a-long-random-token

# Address returned to Patent Agent clients.
KB_MANAGER_PUBLIC_HOST=192.168.130.130
KB_MANAGER_BIND_HOST=0.0.0.0
KB_MANAGER_BIND_PORT=9700

# One free host port is allocated to every managed LightRAG container.
KB_MANAGER_PORT_START=9622
KB_MANAGER_PORT_END=9699
KB_MANAGER_DATA_ROOT=/root/KHJ/lightrag-kbs

# Use the same tested LightRAG image and model configuration as the total KB.
KB_MANAGER_LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
KB_MANAGER_LIGHTRAG_ENV_FILE=/root/KHJ/lightrag-manager/lightrag.env
KB_MANAGER_STARTUP_TIMEOUT=240

# Keep this equal to the API key used by Patent Agent for company LightRAG.
LIGHTRAG_API_KEY=

# Optional when child containers must join a shared model/database network.
KB_MANAGER_DOCKER_NETWORK=
